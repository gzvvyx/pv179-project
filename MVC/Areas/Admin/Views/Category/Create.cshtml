@model CreateCategoryViewModel
@{
    ViewData["Title"] = "Create Category";
}

<div class="container mx-auto px-4 py-8">
    <div class="mb-8 flex items-center justify-between">
        <div>
            <h1 class="text-4xl font-bold">Create Category</h1>
            <p class="text-base-content/70 mt-2">Add a new category</p>
        </div>
        <a asp-action="Index" class="btn btn-ghost">
            <icon name="arrow-left" />
            Back to Categories
        </a>
    </div>

    <div class="card bg-base-100 shadow-xl">
        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                
                <div asp-validation-summary="ModelOnly" class="text-error mb-4"></div>
                
                <div class="grid grid-cols-1 gap-6">
                    <div class="form-control">
                        <label class="label" asp-for="Name">
                            <span class="label-text">Category Name</span>
                        </label>
                        <input type="text" asp-for="Name" class="input input-bordered block" />
                        <span asp-validation-for="Name" class="text-error text-sm"></span>
                    </div>
                </div>

                <div class="form-control mt-6">
                    <div class="flex gap-4 justify-end">
                        <a asp-action="Index" class="btn btn-ghost">Cancel</a>
                        <button type="submit" class="btn btn-primary">
                            <icon name="save" />
                            Create Category
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

