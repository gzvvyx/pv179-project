@model List<GiftCardIndexViewModel>
@{
    ViewData["Title"] = "Gift Card Management";
}

<div class="container mx-auto px-4 py-8">
    <div class="mb-8 flex items-center justify-between">
        <div>
            <h1 class="text-4xl font-bold">Gift Card Management</h1>
            <p class="text-base-content/70 mt-2">View and manage all gift cards</p>
        </div>
        <div class="flex gap-4">
            <a asp-action="Create" class="btn btn-primary">
                <icon name="plus" />
                Create New Gift Card
            </a>
            <a asp-route="AdminIndex" class="btn btn-ghost">
                <icon name="arrow-left" />
                Back to Dashboard
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>@TempData["SuccessMessage"]</span>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-error mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>@TempData["ErrorMessage"]</span>
        </div>
    }

    <div class="card bg-base-100 shadow-xl">
        <div class="card-body">
            <div class="overflow-x-auto">
                <table class="table table-zebra">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Price Reduction</th>
                            <th>Valid From</th>
                            <th>Valid To</th>
                            <th>Codes Count</th>
                            <th>Created At</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var giftCard in Model)
                        {
                            <tr>
                                <td>
                                    <div class="font-bold">#@giftCard.Id</div>
                                </td>
                                <td>
                                    <div class="font-semibold">@giftCard.PriceReduction.ToString("C")</div>
                                </td>
                                <td>
                                    <div class="text-sm">@giftCard.ValidFrom.ToLocalTime().ToString("g")</div>
                                </td>
                                <td>
                                    <div class="text-sm">@giftCard.ValidTo.ToLocalTime().ToString("g")</div>
                                </td>
                                <td>
                                    <span class="badge badge-info">@giftCard.CodesCount</span>
                                </td>
                                <td>
                                    <div class="text-sm">@giftCard.CreatedAt.ToLocalTime().ToString("g")</div>
                                </td>
                                <td>
                                    <div class="flex gap-2">
                                        <a asp-action="Edit" asp-route-id="@giftCard.Id" class="btn btn-sm btn-primary">
                                            <icon name="edit" />
                                            Edit
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@giftCard.Id" method="post" class="inline" onsubmit="return confirm('Are you sure you want to delete this gift card?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-error">
                                                <icon name="trash" />
                                                Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-8">
                                    <p class="text-base-content/70">No gift cards found</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

