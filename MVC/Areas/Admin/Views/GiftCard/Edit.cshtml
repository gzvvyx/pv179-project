@model EditGiftCardViewModel
@{
    ViewData["Title"] = "Edit Gift Card";
}

<div class="container mx-auto px-4 py-8">
    <div class="mb-8 flex items-center justify-between">
        <div>
            <h1 class="text-4xl font-bold">Edit Gift Card #@Model.Id</h1>
            <p class="text-base-content/70 mt-2">Update gift card details and manage codes</p>
        </div>
        <a asp-action="Index" class="btn btn-ghost">
            <icon name="arrow-left" />
            Back to Gift Cards
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success mb-4">
            <icon name="check-circle" />
            <span>@TempData["SuccessMessage"]</span>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-error mb-4">
            <icon name="x-circle" />
            <span>@TempData["ErrorMessage"]</span>
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Gift Card Details -->
        <div class="card bg-base-100 shadow-xl">
            <div class="card-body">
                <h2 class="card-title mb-4">Gift Card Details</h2>
                <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div asp-validation-summary="ModelOnly" class="text-error mb-4"></div>
                    
                    <div class="grid grid-cols-1 gap-6">
                        <div class="form-control">
                            <label class="label">Gift Card ID</label>
                            <input type="text" value="#@Model.Id" class="input input-bordered" disabled />
                        </div>

                        <div class="form-control">
                            <label class="label" asp-for="PriceReduction">
                                <span class="label-text">Price Reduction</span>
                            </label>
                            <input type="number" asp-for="PriceReduction" step="0.01" class="input input-bordered" />
                            <span asp-validation-for="PriceReduction" class="text-error text-sm"></span>
                        </div>

                        <div class="form-control">
                            <label class="label">Valid From</label>
                            <input type="text" value="@Model.ValidFrom.ToLocalTime().ToString("g")" class="input input-bordered" disabled />
                        </div>

                        <div class="form-control">
                            <label class="label">Valid To</label>
                            <input type="text" value="@Model.ValidTo.ToLocalTime().ToString("g")" class="input input-bordered" disabled />
                        </div>

                        <div class="form-control">
                            <label class="label">Created At</label>
                            <input type="text" value="@Model.CreatedAt.ToLocalTime().ToString("g")" class="input input-bordered" disabled />
                        </div>

                        <div class="form-control">
                            <label class="label">Updated At</label>
                            <input type="text" value="@Model.UpdatedAt.ToLocalTime().ToString("g")" class="input input-bordered" disabled />
                        </div>
                    </div>

                    <div class="form-control mt-6">
                        <button type="submit" class="btn btn-primary">
                            <icon name="save" />
                            Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Gift Card Codes -->
        <div class="card bg-base-100 shadow-xl">
            <div class="card-body">
                <h2 class="card-title mb-4">Gift Card Codes</h2>
                
                <!-- Add New Code Form -->
                <div class="mb-6">
                    <h3 class="text-lg font-semibold mb-3">Add New Code</h3>
                    <form asp-action="CreateCode" method="post" class="space-y-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="GiftCardId" value="@Model.Id" />
                        
                        <div class="form-control">
                            <label class="label">
                                <span class="label-text">Code</span>
                            </label>
                            <input type="text" name="Code" class="input input-bordered" required />
                        </div>
                        
                        <button type="submit" class="btn btn-primary btn-sm">
                            <icon name="plus" />
                            Add Code
                        </button>
                    </form>
                </div>

                <div class="divider"></div>

                <!-- Codes List -->
                <div class="overflow-x-auto">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Used</th>
                                <th>Order ID</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var code in Model.Codes)
                            {
                                <tr>
                                    <td>
                                        <div class="font-mono font-semibold">@code.Code</div>
                                    </td>
                                    <td>
                                        @if (code.Used)
                                        {
                                            <span class="badge badge-error">Used</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-success">Available</span>
                                        }
                                    </td>
                                    <td>
                                        @if (code.OrderId.HasValue)
                                        {
                                            <span>#@code.OrderId</span>
                                        }
                                        else
                                        {
                                            <span class="text-base-content/50">-</span>
                                        }
                                    </td>
                                    <td>
                                        <form asp-action="DeleteCode" method="post" class="inline" onsubmit="return confirm('Are you sure you want to delete this code?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="code" value="@code.Code" />
                                            <input type="hidden" name="giftCardId" value="@Model.Id" />
                                            <button type="submit" class="btn btn-xs btn-error">
                                                <icon name="trash" />
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Codes.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-4">
                                        <p class="text-base-content/70">No codes found</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

