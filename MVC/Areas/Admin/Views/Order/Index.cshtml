@model List<OrderIndexViewModel>
@{
    ViewData["Title"] = "Order Management";
}

<div class="container mx-auto px-4 py-8">
    <div class="mb-8 flex items-center justify-between">
        <div>
            <h1 class="text-4xl font-bold">Order Management</h1>
            <p class="text-base-content/70 mt-2">View and manage all orders</p>
        </div>
        <a asp-route="AdminIndex" class="btn btn-ghost">
            <icon name="arrow-left" />
            Back to Dashboard
        </a>
    </div>

    <div class="card bg-base-100 shadow-xl">
        <div class="card-body">
            <div class="overflow-x-auto">
                <table class="table table-zebra">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Orderer</th>
                            <th>Creator</th>
                            <th>Amount</th>
                            <th>Status</th>
                            <th>Created At</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="font-bold">#@item.Id</div>
                                </td>
                                <td>
                                    <div class="font-medium">@item.OrdererUserName</div>
                                    <div class="text-sm opacity-50">@item.OrdererId</div>
                                </td>
                                <td>
                                    <div class="font-medium">@item.CreatorUserName</div>
                                    <div class="text-sm opacity-50">@item.CreatorId</div>
                                </td>
                                <td>
                                    <div class="font-semibold">@item.Amount.ToString("C")</div>
                                </td>
                                <td>
                                    @{
                                        var statusClass = item.Status switch
                                        {
                                            OrderStatus.Pending => "badge-warning",
                                            OrderStatus.Completed => "badge-success",
                                            OrderStatus.Failed => "badge-error",
                                            _ => "badge-ghost"
                                        };
                                    }
                                    <span class="badge @statusClass">@item.Status</span>
                                </td>
                                <td>
                                    <div class="text-sm">@item.CreatedAt.ToLocalTime().ToString("g")</div>
                                </td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">
                                        <icon name="edit" />
                                        Edit
                                    </a>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-8">
                                    <p class="text-base-content/70">No orders found</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

