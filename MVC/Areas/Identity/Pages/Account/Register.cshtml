@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div asp-validation-summary="ModelOnly" class="alert alert-error my-2" role="alert"></div>
<div class="w-lg mx-auto">
    <h1 class="text-2xl text-center mb-4 mt-10">@ViewData["Title"]</h1>
    <div class="row">
        <div class="col-md-4">
            <section>
                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div class="card bg-base-100 shadow-sm">
                        <div class="card-body grid grid-cols-1 gap-2">
                            <div class="input w-full @(ViewData.ModelState["Input.Email"]?.Errors.Count > 0 ? "input-error" : "")">
                                <label asp-for="Input.Email" class="label w-56">Email</label>
                                <input asp-for="Input.Email" autocomplete="username" aria-required="true" />
                            </div>
                            <span asp-validation-for="Input.Email" class="text-error"></span>
                            <div class="input w-full @(ViewData.ModelState["Input.Password"]?.Errors.Count > 0 ? "input-error" : "")">
                                <label asp-for="Input.Password" class="label w-56">Password</label>
                                <input asp-for="Input.Password" autocomplete="new-password" aria-required="true" />
                            </div>
                            <span asp-validation-for="Input.Password" class="text-error"></span>
                            <div class="input w-full @(ViewData.ModelState["Input.ConfirmPassword"]?.Errors.Count > 0 ? "input-error" : "")">
                                <label asp-for="Input.ConfirmPassword" class="label w-56">Confirm Password</label>
                                <input asp-for="Input.ConfirmPassword" autocomplete="new-password" aria-required="true" />
                            </div>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-error"></span>
                            <div>
                                <button id="registerSubmit" type="submit" class="btn btn-primary w-full">Register</button>
                            </div>
                        </div>
                    </div>
                    <div class="grid grid-cols-1 gap-1 text-sm px-6 mt-4 text-gray-600">
                        <a class="link" asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Already have an account? Log in</a>
                    </div>
                </form>
            </section>
        </div>
    </div>
</div>

