@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div asp-validation-summary="ModelOnly" class="alert alert-error my-2" role="alert"></div>
<div class="w-lg mx-auto">
    <h1 class="text-2xl text-center mb-4 mt-10">@ViewData["Title"]</h1>
    <div class="row">
        <div class="col-md-4">
            <section>
                <form id="account" method="post">
                    <div class="card bg-base-100 shadow-sm">
                        <div class="card-body grid grid-cols-1 gap-2">
                            <div class="input w-full @(ViewData.ModelState["Input.Email"]?.Errors.Count > 0 ? "input-error" : "")">
                                <label asp-for="Input.Email" class="label w-32">Email</label>
                                <input asp-for="Input.Email" autocomplete="username" aria-required="true" />
                            </div>
                            <span asp-validation-for="Input.Email" class="text-error"></span>
                            <div class="input w-full @(ViewData.ModelState["Input.Password"]?.Errors.Count > 0 ? "input-error" : "")">
                                <label asp-for="Input.Password" class="label w-32">Password</label>
                                <input asp-for="Input.Password" autocomplete="current-password" aria-required="true" />
                            </div>
                            <span asp-validation-for="Input.Password" class="text-error"></span>
                            <div>
                                <label asp-for="Input.RememberMe" class="label text-sm">
                                    <input class="checkbox" asp-for="Input.RememberMe" />
                                    @Html.DisplayNameFor(m => m.Input.RememberMe)
                                </label>
                            </div>
                            <div>
                                <button id="login-submit" type="submit" class="btn btn-primary w-full">Log in</button>
                            </div>
                        </div>
                    </div>
                    <div class="grid grid-cols-1 gap-1 text-sm px-6 mt-4 text-gray-600">
                        @* <a class="link" id="forgot-password" asp-page="./ForgotPassword">Forgot your password?</a> *@
                        <a class="link" asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Register as a new user</a>
                        @* <a class="link" id="resend-confirmation" asp-page="./ResendEmailConfirmation">Resend email confirmation</a> *@
                    </div>
                </form>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
