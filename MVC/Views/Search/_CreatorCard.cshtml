@using Business.DTOs
@model UserDto

<div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow">
    <div class="card-body items-center text-center">
        <h3 class="card-title text-base">@Model.UserName</h3>
        @if (!string.IsNullOrEmpty(Model.Email))
        {
            <p class="text-xs opacity-60">@Model.Email</p>
        }
        <div class="card-actions mt-2">
            <a asp-controller="User" asp-action="Index" asp-route-id="@Model.Id" class="btn btn-primary btn-sm btn-block">
                <icon name="user-plus" />
                View Profile
            </a>
        </div>
    </div>
</div>
