@using Business.DTOs
@model VideoDto

<div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow">
    <figure class="aspect-video bg-base-300">
        <img src="@Model.ThumbnailUrl" alt="@Model.Title" class="w-full h-full object-cover" />
    </figure>
    <div class="card-body">
        <h3 class="card-title text-base">@Model.Title</h3>
        <p class="text-sm opacity-70 line-clamp-2">@Model.Description</p>
        <div class="card-actions justify-between items-center mt-2">
            <div class="flex flex-col gap-1 flex-1">
                <div class="text-xs opacity-60">
                    <icon name="user" class="w-3 h-3 inline" />
                    @Model.Creator.UserName
                </div>
                @if (Model.Categories.Any())
                {
                    <div class="flex flex-wrap gap-1 items-center">
                        @{
                            var sortedCategories = Model.Categories.OrderByDescending(vc => vc.IsPrimary).ToList();
                            var visibleCategories = sortedCategories.Take(3).ToList();
                            var remainingCount = sortedCategories.Count - 3;
                        }

                        @foreach (var videoCategory in visibleCategories)
                        {
                            @if (videoCategory.IsPrimary)
                            {
                                <span class="badge badge-xs badge-accent gap-1 font-semibold">
                                    @videoCategory.Category.Name
                                </span>
                            }
                            else
                            {
                                <span class="badge badge-xs badge-primary gap-1">
                                    @videoCategory.Category.Name
                                </span>
                            }
                        }

                        @if (remainingCount > 0)
                        {
                            <span class="text-xs opacity-60">+@remainingCount more</span>
                        }
                    </div>
                }
            </div>
            <a asp-controller="VideoDetail" asp-action="Detail" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">
                <icon name="play" />
                Watch
            </a>
        </div>
    </div>
</div>