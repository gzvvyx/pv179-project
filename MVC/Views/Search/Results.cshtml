@using Business.DTOs
@model dynamic
@{
    var isVideo = Model.Results is List<VideoDto>;
    var isPlaylist = Model.Results is List<PlaylistDto>;
    var isUser = Model.Results is List<UserDto>;
    
    ViewData["Title"] = $"{Model.Category} - Search results for \"{Model.Query}\"";
}

<div class="py-8">
    <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <div class="mb-8">
            <a asp-action="Index" asp-route-query="@Model.Query" class="btn btn-ghost btn-sm mb-4">
                <icon name="arrow-left" />
                Back to Search
            </a>
            <h1 class="text-4xl font-bold mb-2 capitalize">@Model.Category</h1>
            <p class="text-lg opacity-70">
                Search results for "<span class="font-semibold">@Model.Query</span>"
            </p>
            
            <!-- Category Filter Tabs -->
            <div class="tabs tabs-boxed mt-4 mb-2">
                <a asp-action="All" asp-route-query="@Model.Query" 
                   class="tab @(Model.Category == "all" ? "tab-active" : "")">
                    <icon name="layers" class="w-4 h-4 mr-2" />
                    All
                </a>
                <a asp-action="Videos" asp-route-query="@Model.Query" 
                   class="tab @(Model.Category == "videos" ? "tab-active" : "")">
                    <icon name="video" class="w-4 h-4 mr-2" />
                    Videos
                </a>
                <a asp-action="Playlists" asp-route-query="@Model.Query" 
                   class="tab @(Model.Category == "playlists" ? "tab-active" : "")">
                    <icon name="list" class="w-4 h-4 mr-2" />
                    Playlists
                </a>
                <a asp-action="Creators" asp-route-query="@Model.Query" 
                   class="tab @(Model.Category == "creators" ? "tab-active" : "")">
                    <icon name="users" class="w-4 h-4 mr-2" />
                    Creators
                </a>
            </div>
            
            <div class="text-sm opacity-60 mt-2">
                Found @Model.Results.Count result(s)
            </div>
        </div>

        @if (Model.Results.Count > 0)
        {
            @if (isVideo)
            {
                <!-- Videos Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    @foreach (VideoDto video in Model.Results)
                    {
                        <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow">
                            <figure class="aspect-video bg-base-300">
                                <img src="@video.ThumbnailUrl" alt="@video.Title" class="w-full h-full object-cover" />
                            </figure>
                            <div class="card-body">
                                <h3 class="card-title">@video.Title</h3>
                                <p class="text-sm opacity-70 line-clamp-3">@video.Description</p>
                                <div class="flex flex-col gap-2 mt-2">
                                    <div class="text-xs opacity-60">
                                        <icon name="user" class="w-3 h-3 inline" />
                                        Creator: @video.CreatorId
                                    </div>
                                    <div class="text-xs opacity-60">
                                        <icon name="calendar" class="w-3 h-3 inline" />
                                        Created: @video.CreatedAt.ToString("MMM dd, yyyy")
                                    </div>
                                </div>
                                <div class="card-actions justify-end mt-4">
                                    <a href="@video.Url" target="_blank" class="btn btn-primary btn-sm">
                                        <icon name="play" />
                                        Watch Video
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else if (isPlaylist)
            {
                <!-- Playlists Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    @foreach (PlaylistDto playlist in Model.Results)
                    {
                        <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow">
                            <div class="card-body">
                                <h3 class="card-title">
                                    <icon name="list" class="w-5 h-5" />
                                    @playlist.Name
                                </h3>
                                @if (!string.IsNullOrEmpty(playlist.Description))
                                {
                                    <p class="text-sm opacity-70">@playlist.Description</p>
                                }
                                <div class="flex flex-col gap-2 mt-2">
                                    <div class="text-xs opacity-60">
                                        <icon name="user" class="w-3 h-3 inline" />
                                        Creator: @playlist.CreatorId
                                    </div>
                                    <div class="text-xs opacity-60">
                                        <icon name="calendar" class="w-3 h-3 inline" />
                                        Created: @playlist.CreatedAt.ToString("MMM dd, yyyy")
                                    </div>
                                </div>
                                <div class="card-actions justify-end mt-4">
                                    <button class="btn btn-primary btn-sm">
                                        <icon name="external-link" />
                                        Open Playlist
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else if (isUser)
            {
                <!-- Users/Creators Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                    @foreach (UserDto user in Model.Results)
                    {
                        <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow">
                            <div class="card-body items-center text-center">
                                <div class="avatar placeholder mb-4">
                                    <div class="bg-neutral text-neutral-content rounded-full w-20">
                                        <span class="text-3xl">@user.UserName?.Substring(0, 1).ToUpper()</span>
                                    </div>
                                </div>
                                <h3 class="card-title text-lg">@user.UserName</h3>
                                @if (!string.IsNullOrEmpty(user.Email))
                                {
                                    <p class="text-xs opacity-60 mb-2">@user.Email</p>
                                }
                                <div class="badge badge-outline badge-sm">Creator</div>
                                <div class="card-actions mt-4 w-full">
                                    <button class="btn btn-primary btn-sm btn-block">
                                        <icon name="user-plus" />
                                        View Profile
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <!-- No Results -->
            <div class="card bg-base-100 shadow-xl">
                <div class="card-body items-center text-center py-12">
                    <icon name="search-x" class="w-16 h-16 opacity-30 mb-4" />
                    <h3 class="text-2xl font-bold mb-2">No @Model.Category found</h3>
                    <p class="opacity-70 mb-4">
                        We couldn't find any @Model.Category matching "<span class="font-semibold">@Model.Query</span>"
                    </p>
                    <div class="card-actions">
                        <a asp-action="Index" class="btn btn-primary">
                            <icon name="arrow-left" />
                            Try a different search
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        lucide.createIcons();
    </script>
}
