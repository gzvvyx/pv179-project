@model AddVideosToPlaylistViewModel
@{
    ViewData["Title"] = $"Add Videos to {Model.Playlist.Name}";
}

<div class="container mx-auto px-4 py-8">
    <!-- Header -->
    <div class="mb-8">
        <a asp-action="Details" asp-route-id="@Model.Playlist.Id" class="btn btn-ghost btn-sm mb-4">
            <icon name="arrow-left" />
            Back to Playlist
        </a>
        
        <h1 class="text-4xl font-bold mb-2">Add Videos to Playlist</h1>
        <p class="text-base-content/70">
            Adding videos to: <span class="font-semibold">@Model.Playlist.Name</span>
        </p>
    </div>

    <!-- Videos List -->
    @if (!Model.UserVideos.Any())
    {
        <div class="card bg-base-100 shadow-xl">
            <div class="card-body items-center text-center py-16">
                <icon name="video-off" class="w-24 h-24 opacity-30 mb-4" />
                <h2 class="text-2xl font-bold mb-2">No Videos Available</h2>
                <p class="text-base-content/70 mb-6">
                    You don't have any videos to add to this playlist.
                </p>
                <div class="flex gap-3 justify-center">
                    <a asp-controller="Search" asp-action="All" class="btn btn-primary">
                        <icon name="search" />
                        Browse Videos
                    </a>
                    <a asp-controller="Video" asp-action="Create" class="btn btn-primary">
                        <icon name="plus" />
                        Upload New Video
                    </a>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            @foreach (var video in Model.UserVideos)
            {
                var isInPlaylist = Model.VideosInPlaylist.Contains(video.Id);
                
                <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow @(isInPlaylist ? "opacity-60" : "")">
                    <figure class="aspect-video bg-base-300 relative">
                        <img src="@video.ThumbnailUrl" alt="@video.Title" class="w-full h-full object-cover" />
                        @if (isInPlaylist)
                        {
                            <div class="absolute top-2 right-2 badge badge-success gap-2">
                                <icon name="check" class="w-3 h-3" />
                                Added
                            </div>
                        }
                    </figure>
                    <div class="card-body p-4">
                        <h3 class="card-title text-base line-clamp-2">@video.Title</h3>
                        <p class="text-sm opacity-70 line-clamp-2">@video.Description</p>
                        
                        <div class="flex flex-col gap-2 mt-2">
                            @if (video.Categories.Any())
                            {
                                <div class="flex flex-wrap gap-1 items-center">
                                    @{
                                        var sortedCategories = video.Categories.OrderByDescending(vc => vc.IsPrimary).ToList();
                                        var visibleCategories = sortedCategories.Take(2).ToList();
                                        var remainingCount = sortedCategories.Count - 2;
                                    }

                                    @foreach (var videoCategory in visibleCategories)
                                    {
                                        @if (videoCategory.IsPrimary)
                                        {
                                            <span class="badge badge-xs badge-accent gap-1 font-semibold">
                                                @videoCategory.Category.Name
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-xs badge-primary gap-1">
                                                @videoCategory.Category.Name
                                            </span>
                                        }
                                    }

                                    @if (remainingCount > 0)
                                    {
                                        <span class="text-xs opacity-60">+@remainingCount</span>
                                    }
                                </div>
                            }
                        </div>
                        
                        <div class="card-actions justify-end mt-3">
                            @if (isInPlaylist)
                            {
                                <button class="btn btn-ghost btn-sm w-full" disabled>
                                    <icon name="check" />
                                    Already in Playlist
                                </button>
                            }
                            else
                            {
                                <form method="post" asp-action="AddVideo" class="w-full">
                                    <input type="hidden" name="playlistId" value="@Model.Playlist.Id" />
                                    <input type="hidden" name="videoId" value="@video.Id" />
                                    <button type="submit" class="btn btn-primary btn-sm w-full">
                                        <icon name="plus" />
                                        Add to Playlist
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div> 
    }
</div>
