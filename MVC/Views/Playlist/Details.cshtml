@model PlaylistDetailViewModel
@{
    ViewData["Title"] = Model.Playlist.Name;
}

<div class="container mx-auto px-4 py-8">
    <!-- Header -->
    <div class="mb-8">
        <button onclick="history.back()" class="btn btn-ghost btn-sm mb-4">
            <icon name="arrow-left" />
            Back
        </button>
        
        <div class="flex justify-between items-start">
            <div class="flex-1">
                <h1 class="text-4xl font-bold mb-2">@Model.Playlist.Name</h1>
                
                @if (!string.IsNullOrEmpty(Model.Playlist.Description))
                {
                    <p class="text-lg text-base-content/70 mb-4">@Model.Playlist.Description</p>
                }
                
                <div class="flex items-center gap-4 text-sm text-base-content/60">
                    <div class="flex items-center gap-2">
                        <icon name="user" class="w-4 h-4" />
                        <span>@Model.Playlist.Creator.UserName</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <icon name="video" class="w-4 h-4" />
                        <span>@Model.Videos.Count video@(Model.Videos.Count != 1 ? "s" : "")</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <icon name="calendar" class="w-4 h-4" />
                        <span>Created @Model.Playlist.CreatedAt.ToString("MMM dd, yyyy")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Videos List -->
    @if (!Model.Videos.Any())
    {
        <div class="card bg-base-100 shadow-xl">
            <div class="card-body items-center text-center py-16">
                <icon name="video-off" class="w-24 h-24 opacity-30 mb-4" />
                <h2 class="text-2xl font-bold mb-2">No Videos Yet</h2>
                <p class="text-base-content/70 mb-6">
                    This playlist is empty. Start adding videos to organize your content!
                </p>
                @if (Model.IsOwner)
                {
                    <a asp-action="AddVideos" asp-route-id="@Model.Playlist.Id" class="btn btn-primary">
                        <icon name="plus" />
                        Add Videos
                    </a>
                }
            </div>
        </div>
    }
    else
    {
        @if (Model.IsOwner)
        {
            <div class="mb-6 flex justify-end">
                <a asp-action="AddVideos" asp-route-id="@Model.Playlist.Id" class="btn btn-primary btn-sm">
                    <icon name="plus" />
                    Videos
                </a>
            </div>
        }
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            @foreach (var video in Model.Videos)
            {
                <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow">
                    <figure class="aspect-video bg-base-300 relative">
                        <img src="@video.ThumbnailUrl" alt="@video.Title" class="w-full h-full object-cover" />
                        @if (Model.IsOwner)
                        {
                            <button onclick="confirmRemoveVideo(@Model.Playlist.Id, @video.Id, '@video.Title.Replace("'", "\\'").Replace("\"", "&quot;")')"
                                    class="absolute top-2 right-2 btn btn-circle btn-sm btn-error opacity-80 hover:opacity-100">
                                <icon name="x" class="w-4 h-4" />
                            </button>
                        }
                    </figure>
                    <div class="card-body p-4">
                        <h3 class="card-title text-base line-clamp-2">@video.Title</h3>
                        <p class="text-sm opacity-70 line-clamp-2">@video.Description</p>
                        
                        <div class="flex flex-col gap-2 mt-2">
                            <div class="text-xs opacity-60">
                                <icon name="user" class="w-3 h-3 inline" />
                                @video.Creator.UserName
                            </div>
                            
                            @if (video.Categories.Any())
                            {
                                <div class="flex flex-wrap gap-1 items-center">
                                    @{
                                        var sortedCategories = video.Categories.OrderByDescending(vc => vc.IsPrimary).ToList();
                                        var visibleCategories = sortedCategories.Take(2).ToList();
                                        var remainingCount = sortedCategories.Count - 2;
                                    }

                                    @foreach (var videoCategory in visibleCategories)
                                    {
                                        @if (videoCategory.IsPrimary)
                                        {
                                            <span class="badge badge-xs badge-accent gap-1 font-semibold">
                                                @videoCategory.Category.Name
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-xs badge-primary gap-1">
                                                @videoCategory.Category.Name
                                            </span>
                                        }
                                    }

                                    @if (remainingCount > 0)
                                    {
                                        <span class="text-xs opacity-60">+@remainingCount</span>
                                    }
                                </div>
                            }
                        </div>
                        
                        <div class="card-actions justify-end mt-3">
                            <a asp-controller="VideoDetail" asp-action="Detail" asp-route-id="@video.Id" 
                               class="btn btn-primary btn-sm w-full">
                                <icon name="play" />
                                Watch
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Remove Video Confirmation Modal -->
<dialog id="removeVideoModal" class="modal">
    <div class="modal-box">
        <h3 class="font-bold text-lg mb-4">Remove Video</h3>
        <p class="py-4" id="removeVideoMessage">Are you sure you want to remove this video from the playlist?</p>
        
        <form id="removeVideoForm" method="post" asp-action="RemoveVideo">
            <input type="hidden" id="removePlaylistId" name="playlistId" />
            <input type="hidden" id="removeVideoId" name="videoId" />
            <div class="modal-action">
                <button type="button" class="btn" onclick="closeRemoveVideoModal()">Cancel</button>
                <button type="submit" class="btn btn-error">Remove</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button>close</button>
    </form>
</dialog>

<!-- Delete Playlist Confirmation Modal -->
<dialog id="deletePlaylistModal" class="modal">
    <div class="modal-box">
        <h3 class="font-bold text-lg mb-4">Delete Playlist</h3>
        <p class="py-4" id="deletePlaylistMessage">Are you sure you want to delete this playlist?</p>
        
        <form id="deletePlaylistForm" method="post" asp-action="Delete">
            <input type="hidden" id="deletePlaylistId" name="id" />
            <div class="modal-action">
                <button type="button" class="btn" onclick="closeDeletePlaylistModal()">Cancel</button>
                <button type="submit" class="btn btn-error">Delete</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button>close</button>
    </form>
</dialog>

@section Scripts {
    <script>
        function confirmRemoveVideo(playlistId, videoId, videoTitle) {
            document.getElementById('removePlaylistId').value = playlistId;
            document.getElementById('removeVideoId').value = videoId;
            document.getElementById('removeVideoMessage').textContent = 
                `Are you sure you want to remove "${videoTitle}" from this playlist?`;
            document.getElementById('removeVideoModal').showModal();
        }

        function closeRemoveVideoModal() {
            document.getElementById('removeVideoModal').close();
        }

        function confirmDeletePlaylist(id, name) {
            document.getElementById('deletePlaylistId').value = id;
            document.getElementById('deletePlaylistMessage').textContent = 
                `Are you sure you want to delete "${name}"? This action cannot be undone. All videos will remain intact.`;
            document.getElementById('deletePlaylistModal').showModal();
        }

        function closeDeletePlaylistModal() {
            document.getElementById('deletePlaylistModal').close();
        }
    </script>
}