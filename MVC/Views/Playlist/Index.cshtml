@model List<PlaylistItemViewModel>
@{
    ViewData["Title"] = "My Playlists";
}

<div class="container mx-auto px-4 py-8">
    <div class="mb-8 flex justify-between items-start">
        <div>
            <h1 class="text-4xl font-bold mb-2">My Playlists</h1>
            <p class="text-base-content/70">Manage your personal playlists</p>
        </div>
        @if (Model.Any())
        {
            <button class="btn btn-primary" onclick="openCreateModal()">
                <icon name="plus" />
                Create New Playlist
            </button>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="card bg-base-100 shadow-xl">
            <div class="card-body items-center text-center py-16">
                <icon name="list" class="w-24 h-24 opacity-30 mb-4" />
                <h2 class="text-2xl font-bold mb-2">No Playlists Yet</h2>
                <p class="text-base-content/70 mb-6">
                    You haven't created any playlists yet. Start organizing your favorite videos!
                </p>
                <button class="btn btn-primary" onclick="openCreateModal()">
                    <icon name="plus" />
                    Create Your First Playlist
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var playlist in Model)
            {
                <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow">
                    <div class="card-body">
                        <h2 class="card-title">
                            <icon name="list" class="w-5 h-5" />
                            @playlist.Name
                        </h2>
                        
                        @if (!string.IsNullOrEmpty(playlist.Description))
                        {
                            <p class="text-sm text-base-content/70 line-clamp-2">
                                @playlist.Description
                            </p>
                        }
                        else
                        {
                            <p class="text-sm text-base-content/50 italic">
                                No description
                            </p>
                        }

                        <div class="card-actions justify-end mt-4">
                            <a asp-action="Details" asp-route-id="@playlist.Id" class="btn btn-ghost btn-sm">
                                <icon name="eye" />
                                View
                            </a>
                            <button class="btn btn-error btn-sm" 
                                    onclick="confirmDelete(@playlist.Id, '@playlist.Name.Replace("'", "\\'")  ')">
                                <icon name="trash-2" />
                                Delete
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Create Playlist Modal -->
<dialog id="createModal" class="modal">
    <div class="modal-box max-w-2xl">
        <form method="dialog">
            <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">
                <icon name="x" />
            </button>
        </form>
        
        <h3 class="font-bold text-2xl mb-2">Create New Playlist</h3>
        <p class="text-base-content/70 mb-6">Organize your favorite videos into a playlist</p>
        
        <form id="createPlaylistForm" method="post" asp-action="Create">
            <!-- Playlist Name -->
            <div class="form-control mb-4">
                <label class="label">
                    <span class="label-text font-semibold">
                        Playlist Name <span class="text-error">*</span>
                    </span>
                </label>
                <input type="text" 
                       name="name" 
                       id="playlistName"
                       placeholder="e.g., My Favorite Gaming Videos"
                       class="input input-bordered w-full"
                       maxlength="100"
                       required />
                <label class="label">
                    <span class="label-text-alt text-base-content/60">
                        Choose a descriptive name for your playlist
                    </span>
                    <span class="label-text-alt" id="nameCounter">0/100</span>
                </label>
            </div>

            <!-- Description -->
            <div class="form-control mb-6">
                <label class="label">
                    <span class="label-text font-semibold">Description (Optional)</span>
                </label>
                <textarea name="description" 
                          id="playlistDescription"
                          class="textarea textarea-bordered h-32"
                          placeholder="Describe what this playlist is about..."
                          maxlength="500"></textarea>
                <label class="label">
                    <span class="label-text-alt text-base-content/60">
                        Add a brief description to help others understand your playlist
                    </span>
                    <span class="label-text-alt" id="descCounter">0/500</span>
                </label>
            </div>

            <!-- Action Buttons -->
            <div class="flex gap-3 justify-end pt-4 border-t">
                <button type="button" class="btn btn-ghost" onclick="closeCreateModal()">
                    Cancel
                </button>
                <button type="submit" class="btn btn-primary" id="createBtn">
                    <icon name="plus" />
                    Create Playlist
                </button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button>close</button>
    </form>
</dialog>

<!-- Delete Confirmation Modal -->
<dialog id="deleteModal" class="modal">
    <div class="modal-box">
        <h3 class="font-bold text-lg mb-4">Confirm Delete</h3>
        <p class="py-4" id="deleteMessage">Are you sure you want to delete this playlist?</p>
        
        <form id="deleteForm" method="post" asp-action="Delete">
            <input type="hidden" id="playlistIdInput" name="id" />
            <div class="modal-action">
                <button type="button" class="btn" onclick="closeDeleteModal()">Cancel</button>
                <button type="submit" class="btn btn-error">Delete</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button>close</button>
    </form>
</dialog>

@section Scripts {
    <script>
        function confirmDelete(id, name) {
            document.getElementById('playlistIdInput').value = id;
            document.getElementById('deleteMessage').textContent = 
                `Are you sure you want to delete "${name}"? This action cannot be undone.`;
            document.getElementById('deleteModal').showModal();
        }

        function closeDeleteModal() {
            document.getElementById('deleteModal').close();
        }

        function openCreateModal() {
            resetCreateForm();
            document.getElementById('createModal').showModal();
        }

        function closeCreateModal() {
            document.getElementById('createModal').close();
            resetCreateForm();
        }

        function resetCreateForm() {
            document.getElementById('createPlaylistForm').reset();
            document.getElementById('nameCounter').textContent = '0/100';
            document.getElementById('descCounter').textContent = '0/500';
        }

        document.getElementById('playlistName')?.addEventListener('input', function(e) {
            const length = e.target.value.length;
            document.getElementById('nameCounter').textContent = `${length}/100`;
        });

        document.getElementById('playlistDescription')?.addEventListener('input', function(e) {
            const length = e.target.value.length;
            document.getElementById('descCounter').textContent = `${length}/500`;
        });
    </script>
}