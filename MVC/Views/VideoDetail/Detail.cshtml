@using Business.DTOs
@using System.Security.Claims
@model MVC.Models.VideoDetailViewModel
@{
    ViewData["Title"] = Model.Video.Title;
    var sortedCategories = Model.Video.Categories.OrderByDescending(vc => vc.IsPrimary).ToList();
    var visibleCategories = sortedCategories.Take(3).ToList();
    var remainingCount = sortedCategories.Count - 3;
    var currentUserId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    var isOwner = !string.IsNullOrEmpty(currentUserId) && Model.Video.Creator.Id == currentUserId;
    var returnUrl = Model.ReturnUrl ?? Context.Request.Headers["Referer"].ToString();
    var showBackButton = !string.IsNullOrEmpty(returnUrl) && returnUrl.Contains("/Search/All");
}

<div class="container mx-auto px-4 py-8">
    <button onclick="history.back()" class="btn btn-ghost btn-sm mb-4">
        <icon name="arrow-left" />
        Back
    </button>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success mb-4">
            <icon name="check-circle" size="24" />
            <span>@TempData["SuccessMessage"]</span>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-error mb-4">
            <icon name="x-circle" size="24" />
            <span>@TempData["ErrorMessage"]</span>
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Video Player Section -->
        <div class="lg:col-span-2">
            <div class="card bg-base-100 shadow-xl">
                <figure class="aspect-video bg-black">
                    @if (!string.IsNullOrEmpty(Model.Video.Url))
                    {
                        <video class="w-full h-full" controls>
                            <source src="@Model.Video.Url" type="video/mp4">
                            Your browser does not support the video tag.
                        </video>
                    }
                    else
                    {
                        <div class="flex items-center justify-center h-full">
                            <span class="text-xl opacity-50">No video available</span>
                        </div>
                    }
                </figure>
                
                <div class="card-body">
                    <h1 class="card-title text-2xl md:text-3xl">@Model.Video.Title</h1>
                    
                    <!-- Published and Updated Info -->
                    <div class="flex flex-wrap items-center gap-4 text-sm opacity-70 my-2">
                        <div class="flex items-center gap-1">
                            <icon name="user" class="w-4 h-4" />
                            <span class="font-medium">@Model.Video.Creator.UserName</span>
                        </div>
                        <span>•</span>
                        <div class="flex items-center gap-1">
                            <icon name="calendar" class="w-4 h-4" />
                            <span>Published @Model.Video.CreatedAt.ToString("MMM dd, yyyy")</span>
                        </div>
                        @if (Model.Video.UpdatedAt > Model.Video.CreatedAt.AddMinutes(1))
                        {
                            <span>•</span>
                            <div class="flex items-center gap-1">
                                <icon name="clock" class="w-4 h-4" />
                                <span>Updated @Model.Video.UpdatedAt.ToString("MMM dd, yyyy")</span>
                            </div>
                        }
                    </div>

                    @if (Model.Video.Categories.Any())
                    {
                        <div class="flex flex-wrap gap-2 my-3">
                            @foreach (var videoCategory in visibleCategories)
                            {
                                if (videoCategory.IsPrimary)
                                {
                                    <span class="badge badge-accent gap-1">
                                        @videoCategory.Category.Name
                                    </span>
                                }
                                else
                                {
                                    <span class="badge badge-primary gap-1">
                                        @videoCategory.Category.Name
                                    </span>
                                }
                            }
                            @if (remainingCount > 0)
                            {
                                <span class="badge badge-ghost">+@remainingCount more</span>
                            }
                        </div>
                    }

                    <div class="divider my-2"></div>

                    <div class="prose max-w-none">
                        <h3 class="text-lg font-semibold mb-2">Description</h3>
                        <p class="whitespace-pre-wrap">@Model.Video.Description</p>
                    </div>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="divider my-2"></div>
                        
                        <div class="flex gap-2">
                            <button onclick="openAddToPlaylistModal()" class="btn btn-primary btn-sm">
                                <icon name="list" />
                                Add to Playlist
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Comments Sidebar Section -->
        <div class="lg:col-span-1">
            @if (isOwner)
            {
                <div class="card bg-base-100 shadow-xl mb-6">
                    <div class="card-body p-4">
                        <h3 class="card-title text-lg mb-2">Owner Actions</h3>
                        <div class="flex gap-2">
                            <a asp-controller="Video" asp-action="Edit" asp-route-id="@Model.Video.Id" class="btn btn-primary btn-sm flex-1">
                                <icon name="edit" />
                                Edit
                            </a>
                            
                            <form asp-controller="Video" asp-action="Delete" asp-route-id="@Model.Video.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this video? This action cannot be undone.');" class="flex-1">
                                <button type="submit" class="btn btn-error btn-outline btn-sm w-full">
                                    <icon name="trash" />
                                    Delete
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
            <partial name="_CommentSection" model="Model" />
        </div>
    </div>
</div>

<!-- Add to Playlist Modal -->
@if (User.Identity?.IsAuthenticated == true)
{
    <dialog id="addToPlaylistModal" class="modal">
        <div class="modal-box max-w-md">
            <form method="dialog">
                <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">
                    <icon name="x" />
                </button>
            </form>
            
            <h3 class="font-bold text-xl mb-4">Add to Playlist</h3>
            
            @if (!Model.UserPlaylists.Any())
            {
                <div class="text-center py-8">
                    <icon name="list" class="w-16 h-16 opacity-30 mx-auto mb-4" />
                    <p class="text-base-content/70 mb-4">You don't have any playlists yet.</p>
                    <a asp-controller="Playlist" asp-action="Index" class="btn btn-primary btn-sm">
                        <icon name="plus" />
                        Create a Playlist
                    </a>
                </div>
            }
            else
            {
                <p class="text-sm text-base-content/70 mb-4">Select a playlist to add this video to:</p>
                
                <div class="space-y-2 max-h-96 overflow-y-auto">
                    @foreach (var playlist in Model.UserPlaylists)
                    {
                        var isInPlaylist = Model.PlaylistsContainingVideo.Contains(playlist.Id);
                        
                        <div class="card bg-base-200 hover:bg-base-300 transition-colors @(isInPlaylist ? "opacity-60" : "")">
                            <div class="card-body p-4">
                                <div class="flex items-start justify-between gap-2">
                                    <div class="flex-1">
                                        <h4 class="font-semibold">@playlist.Name</h4>
                                        @if (!string.IsNullOrEmpty(playlist.Description))
                                        {
                                            <p class="text-xs text-base-content/70 line-clamp-2">@playlist.Description</p>
                                        }
                                    </div>
                                    
                                    @if (isInPlaylist)
                                    {
                                        <div class="badge badge-success gap-1">
                                            <icon name="check" class="w-3 h-3" />
                                            Added
                                        </div>
                                    }
                                    else
                                    {
                                        <form method="post" asp-action="AddToPlaylist" asp-route-returnUrl="@Model.ReturnUrl">
                                            <input type="hidden" name="videoId" value="@Model.Video.Id" />
                                            <input type="hidden" name="playlistId" value="@playlist.Id" />
                                            <button type="submit" class="btn btn-primary btn-sm">
                                                <icon name="plus" />
                                                Add
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
                
                <div class="mt-4 pt-4 border-t">
                    <a asp-controller="Playlist" asp-action="Index" class="btn btn-ghost btn-sm w-full">
                        <icon name="settings" />
                        Manage Playlists
                    </a>
                </div>
            }
        </div>
        <form method="dialog" class="modal-backdrop">
            <button>close</button>
        </form>
    </dialog>
}

@section Scripts {
    <script>
        function openAddToPlaylistModal() {
            document.getElementById('addToPlaylistModal')?.showModal();
        }
        
        function toggleReplyForm(commentId) {
            const form = document.getElementById(`reply-form-${commentId}`);
            if (form) {
                form.classList.toggle('hidden');
                if (!form.classList.contains('hidden')) {
                    form.querySelector('textarea')?.focus();
                }
            }
        }
    </script>
}