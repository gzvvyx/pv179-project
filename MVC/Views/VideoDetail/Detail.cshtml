@using Business.DTOs
@model VideoDto
@{
    ViewData["Title"] = Model.Title;
    var sortedCategories = Model.Categories.OrderByDescending(vc => vc.IsPrimary).ToList();
    var visibleCategories = sortedCategories.Take(3).ToList();
    var remainingCount = sortedCategories.Count - 3;
}

<a asp-controller="Search" asp-action="All" class="btn btn-ghost mb-4">
    <icon name="arrow-left" />
    Back to Search
</a>

<div class="max-w-3xl mx-auto py-8">
    <div class="aspect-video bg-base-300 flex items-center justify-center rounded-lg mb-6" style="min-height:320px;">
        <span class="text-2xl opacity-50">Mock Video Player</span>
    </div>
    <h1 class="text-3xl font-bold mb-2">@Model.Title</h1>
    <div class="mb-4 text-base opacity-70">@Model.Description</div>
    <div class="flex flex-wrap gap-1 items-center mb-6">
        @foreach (var videoCategory in visibleCategories)
        {
            if (videoCategory.IsPrimary)
            {
                <span class="badge badge-xs badge-accent gap-1 font-semibold">
                    @videoCategory.Category.Name
                </span>
            }
            else
            {
                <span class="badge badge-xs badge-primary gap-1">
                    @videoCategory.Category.Name
                </span>
            }
        }
        @if (remainingCount > 0)
        {
            <span class="text-xs opacity-60">+@remainingCount more</span>
        }
    </div>
    <div class="text-sm opacity-60 mb-2">
        Uploaded by <b>@Model.Creator.UserName</b> on @Model.CreatedAt.ToShortDateString()
    </div>
</div>