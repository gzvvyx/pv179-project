@using Business.DTOs
@model Tuple<CommentDto, int, string, string, int>
@{
    var comment = Model.Item1;
    var level = Model.Item2;
    var currentUserId = Model.Item3;
    var returnUrl = Model.Item4;
    var videoId = Model.Item5;
    
    var isCommentAuthor = !string.IsNullOrEmpty(currentUserId) && comment.Author.Id == currentUserId;
    var hasReplies = comment.Replies != null && comment.Replies.Any();
    var canDelete = isCommentAuthor && !hasReplies;
    var marginClass = level > 0 ? $"ml-{Math.Min(level * 4, 12)}" : "";
}

<div class="@marginClass">
    <div class="card bg-base-200 border border-base-300 mb-2">
        <div class="card-body p-3">
            <div class="flex items-start gap-2">
                <div class="avatar placeholder flex-shrink-0">
                    <div class="bg-neutral text-neutral-content rounded-full w-8 h-8">
                        <span class="text-xs">@comment.Author.UserName.Substring(0, Math.Min(2, comment.Author.UserName.Length)).ToUpper()</span>
                    </div>
                </div>
                
                <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between mb-1">
                        <div class="flex flex-col">
                            <span class="font-semibold text-sm">@comment.Author.UserName</span>
                            <span class="text-xs opacity-60">@comment.CreatedAt.ToLocalTime().ToString("MMM dd 'at' hh:mm tt")</span>
                        </div>
                                    
                        @if (canDelete)
                        {
                            <form asp-controller="VideoDetail" asp-action="DeleteComment" asp-route-id="@videoId" asp-route-commentId="@comment.Id" asp-route-returnUrl="@returnUrl" method="post" class="inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-ghost btn-xs text-error" onclick="return confirm('Delete this comment?')">
                                    <icon name="trash-2" class="w-3 h-3" />
                                </button>
                            </form>
                        }
                        else if (isCommentAuthor && hasReplies)
                        {
                            <div class="tooltip">
                                <button type="button" class="btn btn-ghost btn-xs text-base-content opacity-30" disabled>
                                    <icon name="trash-2" class="w-3 h-3" />
                                </button>
                            </div>
                        }
                    </div>
                    
                    <p class="text-sm whitespace-pre-wrap break-words mb-2">@comment.Content</p>
                    
                    @if (Context.User.Identity?.IsAuthenticated == true)
                    {
                        <button onclick="toggleReplyForm(@comment.Id)" class="btn btn-ghost btn-xs text-primary">
                            <icon name="corner-down-right" class="w-3 h-3" />
                            Reply
                        </button>
                    }
                    
                    <!-- Reply Form (initially hidden) -->
                    <div id="reply-form-@comment.Id" class="mt-2 hidden">
                        <form asp-controller="VideoDetail" asp-action="AddComment" asp-route-id="@videoId" asp-route-returnUrl="@returnUrl" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="parentCommentId" value="@comment.Id" />
                            <div class="form-control">
                                <textarea 
                                    name="content" 
                                    class="textarea textarea-bordered textarea-sm h-16 text-sm" 
                                    placeholder="Write a reply..."
                                    maxlength="500"
                                    required></textarea>
                            </div>
                            <div class="flex gap-2 mt-2">
                                <button type="submit" class="btn btn-primary btn-xs">
                                    <icon name="send" class="w-3 h-3" />
                                    Reply
                                </button>
                                <button type="button" onclick="toggleReplyForm(@comment.Id)" class="btn btn-ghost btn-xs">
                                    Cancel
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    @* Render replies recursively *@
    @if (hasReplies)
    {
        <div class="ml-4 border-l-2 border-base-300 pl-2">
            @foreach (var reply in comment.Replies.OrderBy(r => r.CreatedAt))
            {
                <partial name="_CommentItem" model="@(new Tuple<CommentDto, int, string, string, int>(reply, level + 1, currentUserId, returnUrl, videoId))" />
            }
        </div>
    }
</div>
