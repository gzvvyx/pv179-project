@using Business.DTOs
@using System.Security.Claims
@model MVC.Models.VideoDetailViewModel
@{
    var currentUserId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    var returnUrl = Model.ReturnUrl ?? Context.Request.Headers["Referer"].ToString();
}

<div class="card bg-base-100 shadow-xl h-full">
    <div class="card-body flex flex-col h-full">
        <h2 class="card-title text-xl mb-4">
            <icon name="message-square" />
            Comments (@Model.CommentCount)
        </h2>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <!-- Add Comment Form -->
            <form asp-action="AddComment" asp-route-id="@Model.Video.Id" asp-route-returnUrl="@returnUrl" method="post" class="mb-4">
                @Html.AntiForgeryToken()
                <div class="form-control">
                    <textarea 
                        name="content" 
                        class="textarea textarea-bordered h-20 text-sm" 
                        placeholder="Add a comment..."
                        maxlength="500"
                        required></textarea>
                    <label class="label">
                        <span class="label-text-alt">Max 500 characters</span>
                    </label>
                </div>
                <button type="submit" class="btn btn-primary btn-sm w-full">
                    <icon name="send" class="w-4 h-4" />
                    Post Comment
                </button>
            </form>
        }
        else
        {
            <div class="alert alert-info mb-4">
                <icon name="info" size="16" />
                <span class="text-xs">Please <a href="/Identity/Account/Login" class="link link-primary">log in</a> to comment.</span>
            </div>
        }

        <div class="divider my-2"></div>

        <!-- Comments List (Scrollable) -->
        <div class="flex-1 overflow-y-auto space-y-3" style="max-height: 600px;">
            @if (Model.Comments.Any())
            {
                @foreach (var comment in Model.Comments.OrderByDescending(c => c.CreatedAt))
                {
                    var isCommentAuthor = !string.IsNullOrEmpty(currentUserId) && comment.Author.Id == currentUserId;
                    
                    <div class="card bg-base-200 border border-base-300">
                        <div class="card-body p-3">
                            <div class="flex items-start gap-2">
                                <div class="avatar placeholder flex-shrink-0">
                                    <div class="bg-neutral text-neutral-content rounded-full w-8 h-8">
                                        <span class="text-xs">@comment.Author.UserName.Substring(0, Math.Min(2, comment.Author.UserName.Length)).ToUpper()</span>
                                    </div>
                                </div>
                                
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center justify-between mb-1">
                                        <div class="flex flex-col">
                                            <span class="font-semibold text-sm">@comment.Author.UserName</span>
                                            <span class="text-xs opacity-60">@comment.CreatedAt.ToLocalTime().ToString("MMM dd 'at' hh:mm tt")</span>
                                        </div>
                                                        
                                        @if (isCommentAuthor)
                                        {
                                            <form asp-action="DeleteComment" asp-route-id="@Model.Video.Id" asp-route-commentId="@comment.Id" asp-route-returnUrl="@returnUrl" method="post" class="inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-ghost btn-xs text-error" onclick="return confirm('Delete this comment?')">
                                                    <icon name="trash-2" class="w-3 h-3" />
                                                </button>
                                            </form>
                                        }
                                    </div>
                                    
                                    <p class="text-sm whitespace-pre-wrap break-words">@comment.Content</p>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-8 opacity-60">
                    <icon name="message-square" size="32" class="mx-auto mb-2" />
                    <p class="text-sm">No comments yet</p>
                </div>
            }
        </div>
    </div>
</div>