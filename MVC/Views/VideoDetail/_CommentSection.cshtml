@using Business.DTOs
@using System.Security.Claims
@model MVC.Models.VideoDetailViewModel
@{
    var currentUserId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    var returnUrl = Model.ReturnUrl ?? Context.Request.Headers["Referer"].ToString();
    
    var topLevelComments = Model.Comments.Where(c => c.ParentCommentId == null).OrderByDescending(c => c.CreatedAt).ToList();
    var videoId = Model.Video.Id;
}

<div class="card bg-base-100 shadow-xl h-full">
    <div class="card-body flex flex-col h-full">
        <h2 class="card-title text-xl mb-4">
            <icon name="message-square" />
            Comments (@Model.CommentCount)
        </h2>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <!-- Add Comment Form -->
            <form asp-action="AddComment" asp-route-id="@videoId" asp-route-returnUrl="@returnUrl" method="post" class="mb-4">
                @Html.AntiForgeryToken()
                <div class="form-control">
                    <textarea 
                        name="content" 
                        class="textarea textarea-bordered h-20 text-sm w-full mb-2" 
                        placeholder="Add a comment..."
                        maxlength="500"
                        required></textarea>
                </div>
                <button type="submit" class="btn btn-primary btn-sm w-full">
                    <icon name="send" class="w-4 h-4" />
                    Post Comment
                </button>
            </form>
        }
        else
        {
            <div class="alert alert-info mb-4">
                <icon name="info" size="16" />
                <span class="text-xs">Please <a href="/Identity/Account/Login" class="link link-primary">log in</a> to comment.</span>
            </div>
        }

        <div class="divider my-2"></div>

        <!-- Comments List (Scrollable) -->
        <div class="flex-1 overflow-y-auto space-y-3" style="max-height: 600px;">
            @if (topLevelComments.Any())
            {
                @foreach (var comment in topLevelComments)
                {
                    <partial name="_CommentItem" model="@(new Tuple<CommentDto, int, string, string, int>(comment, 0, currentUserId ?? "", returnUrl, videoId))" />
                }
            }
            else
            {
                <div class="text-center py-8 opacity-60">
                    <icon name="message-square" size="32" class="mx-auto mb-2" />
                    <p class="text-sm">No comments yet</p>
                </div>
            }
        </div>
    </div>
</div>