@model pv179.Models.UserViewModel
@{
    ViewData["Title"] = Model.UserName;
    bool isLocked = !Model.IsCurrentUser && !Model.IsSubscribed;
}

<div class="card bg-base-100 shadow-xl mb-8 border border-base-200 mt-4">
    <div class="card-body flex flex-row items-center gap-6">
        <div class="flex-1">
            <h2 class="card-title text-3xl">@Model.UserName</h2>
            <p class="opacity-60">@Model.Email</p>
        </div>

        <div id="subscription-ui">
            @if (!Model.IsCurrentUser)
            {
                @if (Model.IsSubscribed)
                {
                    <button class="btn btn-ghost border-base-300 rounded-full px-8 gap-2">
                        <i class="bi bi-check-lg text-success"></i> Subscribed
                    </button>
                }
            }
            else
            {
                <a asp-controller="User" asp-action="Edit" class="btn btn-outline rounded-full px-8">
                    Edit Profile
                </a>
            }
        </div>
    </div>
</div>

<div class="relative">

    @if (isLocked)
    {
        <div class="absolute inset-0 z-20 flex flex-col items-center justify-center bg-base-100/20 backdrop-blur-md rounded-box border border-base-300">
            <div class="bg-base-100 p-8 rounded-2xl shadow-2xl text-center max-w-sm border border-primary/10">
                <h3 class="text-2xl font-bold mb-2">Exclusive Content</h3>
                <p class="opacity-70 mb-6">Subscribe to see @Model.UserName's full library of videos and playlists.</p>
                <a asp-controller="Subscription" asp-action="Subscribe" asp-route-creatorId="@Model.Id"
                   class="btn btn-primary btn-block rounded-full">
                    Subscribe to Unlock @(Model.PricePerMonth.HasValue ? $"for {Model.PricePerMonth.Value.ToString("F2")}$" : "for free")
                </a>
            </div>
        </div>
    }

    <div class="@(isLocked ? "blur-md select-none pointer-events-none opacity-50" : "")">
        <div role="tablist" class="tabs tabs-lift bg-base-200 p-2">
            <input type="radio" name="user_tabs" role="tab" class="tab h-auto py-4 text-xl ml-4" aria-label="Videos" checked />
            <div role="tabpanel" class="tab-content bg-base-100 border-base-300 rounded-box p-6 shadow-xl min-h-[400px]">
                <h4 class="text-lg font-bold mb-6">
                    Videos <span class="badge badge-secondary ml-2">@Model.Videos.TotalCount</span>
                </h4>

                <div id="video-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    @foreach (var video in Model.Videos.Items)
                    {
                        <partial name="_VideoCard" model="video" />
                    }
                </div>

                <div id="video-load-more" class="mt-10 text-center">
                    @if (Model.HasMore(Model.Videos))
                    {
                        <button class="btn btn-outline btn-primary rounded-full px-10"
                                hx-get="@Url.Action("LoadMoreVideos", "User", new { userId = Model.Id, page = 2 })"
                                hx-target="#video-grid"
                                hx-swap="beforeend">
                            Show More
                        </button>
                    }
                </div>
            </div>

            <input type="radio" name="user_tabs" role="tab" class="tab h-auto py-4 text-xl" aria-label="Playlists" />
            <div role="tabpanel" class="tab-content bg-base-100 border-base-300 rounded-box p-6 mt-4 shadow-xl min-h-[400px]">
                <h4 class="text-lg font-bold mb-6">
                    Playlists <span class="badge badge-accent ml-2">@Model.Playlists.TotalCount</span>
                </h4>

                <div id="playlist-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    @foreach (var playlist in Model.Playlists.Items)
                    {
                        <partial name="_PlaylistCard" model="playlist" />
                    }
                </div>

                <div id="playlist-load-more" class="mt-10 text-center">
                    @if (Model.HasMore(Model.Playlists))
                    {
                        <button class="btn btn-outline btn-primary rounded-full px-10"
                                hx-get="@Url.Action("LoadMorePlaylists", "User", new { userId = Model.Id, page = 2 })"
                                hx-target="#playlist-grid"
                                hx-swap="beforeend">
                            Show More
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
