@model pv179.Models.UserDetailsViewModel
@{
    ViewData["Title"] = Model.UserName;
}

<div class="container">
    <div class="d-flex">
        <div class="d-flex align-items-center">
            <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center me-3 text-white">
                @Model.UserName
            </div>
            <p class="text-muted small mb-0"><i class="bi bi-envelope-fill me-1"></i> @Model.Email</p>
        </div>

        <div>
            <button class="btn btn-danger btn-lg rounded-pill fw-bold px-4">
                <i class="bi bi-bell-fill me-2"></i>Subscribe
            </button>
        </div>
    </div>

    <ul class="nav nav-pills nav-fill bg-light mb-4 rounded p-2 shadow-sm" id="profileTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active py-3" id="videos-tab" data-bs-toggle="tab" data-bs-target="#videos" type="button" role="tab">
                <span class="d-block fw-bold">Videos</span>
                <small>@Model.VideoCount</small>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link py-3" id="playlists-tab" data-bs-toggle="tab" data-bs-target="#playlists" type="button" role="tab">
                <span class="d-block fw-bold">Playlists</span>
                <small>@Model.PlaylistCount</small>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link py-3" id="comments-tab" data-bs-toggle="tab" data-bs-target="#comments" type="button" role="tab">
                <span class="d-block fw-bold">Comments</span>
                <small>@Model.CommentCount</small>
            </button>
        </li>
    </ul>

    <div class="tab-content rounded border bg-white" id="profileTabsContent">

        <div class="tab-pane fade show active p-4" id="videos" role="tabpanel">
            <h4 class="mb-4">Uploaded Videos</h4>
            @if (!Model.UploadedVideos.Any())
            {
                <div class="py-5 text-center">
                    <i class="bi bi-camera-video text-muted display-4"></i>
                    <p class="text-muted mt-2">No videos uploaded yet.</p>
                </div>
            }
            else
            {
                <div class="list-group list-group-flush">
                    @foreach (var video in Model.UploadedVideos)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center py-3">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-play-circle-fill text-primary fs-4 me-3"></i>
                                <h6 class="mb-0">@video.Title</h6>
                            </div>
                            <a asp-action="Details" asp-controller="Videos" asp-route-id="@video.Id" class="btn btn-sm btn-outline-primary rounded-pill">Watch</a>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="tab-pane fade p-4" id="playlists" role="tabpanel">
            <h4 class="mb-4">Playlists</h4>
            <div class="row row-cols-1 row-cols-md-2 g-3">
                @foreach (var playlist in Model.CreatedPlaylists)
                {
                    <div class="col">
                        <div class="card bg-light border-0 shadow-sm">
                            <div class="card-body">
                                <h6 class="card-title fw-bold">@playlist.Name</h6>
                                <a href="#" class="btn btn-sm btn-link text-decoration-none p-0">View Playlist &rarr;</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="tab-pane fade p-4" id="comments" role="tabpanel">
            <h4 class="mb-4">Comments</h4>
            @foreach (var comment in Model.Comments)
            {
                <div class="d-flex mb-4">
                    <div class="me-3">
                        <i class="bi bi-chat-left-text text-muted fs-5"></i>
                    </div>
                    <div class="border-bottom w-100 pb-3">
                        <p class="text-dark mb-1">@comment.Content</p>
                        <small class="text-muted">Posted on @comment.CreatedAt.ToString("MMM dd, yyyy")</small>
                    </div>
                </div>
            }
        </div>

    </div>
</div>