@model pv179.Models.UserEditViewModel

<div class="max-w-2xl mx-auto py-10">
    <form asp-action="Edit" method="post" class="card bg-base-100 shadow-xl border border-base-200">
        <div class="card-body">
            <h2 class="card-title text-2xl mb-4">Edit Profile</h2>

            <div asp-validation-summary="ModelOnly" class="alert alert-error mb-4 text-sm"></div>

            <input type="hidden" asp-for="Id" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="form-control">
                    <label class="label"><span class="label-text font-bold">Username</span></label>
                    <input asp-for="UserName" class="input input-bordered" />
                    <span asp-validation-for="UserName" class="text-error text-xs mt-1"></span>
                </div>

                <div class="form-control">
                    <label class="label"><span class="label-text font-bold">Email</span></label>
                    <input asp-for="Email" type="email" class="input input-bordered" />
                    <span asp-validation-for="Email" class="text-error text-xs mt-1"></span>
                </div>
            </div>

            <div class="form-control mt-2">
                <label class="label"><span class="label-text font-bold">Subscription Price</span></label>
                <label class="input input-bordered flex items-center gap-2">
                    $ <input asp-for="PricePerMonth" type="number" step="0.01" class="grow" />
                </label>
            </div>

            <div class="divider mt-8">Change Password (Optional)</div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="form-control">
                    <label class="label"><span class="label-text">New Password</span></label>
                    <input asp-for="NewPassword" type="password" class="input input-bordered" placeholder="••••••••" />
                </div>
                <div class="form-control">
                    <label class="label"><span class="label-text">Confirm Password</span></label>
                    <input asp-for="ConfirmPassword" type="password" class="input input-bordered" placeholder="••••••••" />
                </div>
            </div>
            <span asp-validation-for="ConfirmPassword" class="text-error text-xs mt-1"></span>

            <div class="card-actions justify-end mt-8">
                <a asp-action="Index" class="btn btn-ghost">Cancel</a>
                <button type="submit" class="btn btn-primary px-10">Save Changes</button>
            </div>
        </div>
    </form>
</div>