@using Business.DTOs
@model PlaylistDto

<div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow">
    <div class="card-body">
        <h3 class="card-title">
            <icon name="list" class="w-5 h-5" />
            @Model.Name
        </h3>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="text-sm opacity-70 line-clamp-3">@Model.Description</p>
        }
        <div class="card-actions justify-between items-center mt-2">
            <div class="text-xs opacity-60">
                <icon name="user" class="w-3 h-3 inline" />
                <a asp-controller="User" asp-action="Index" asp-route-id="@Model.Creator.Id" class="link link-hover">@Model.Creator.UserName</a>
            </div>
            <a asp-controller="Playlist" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">
                <icon name="external-link" />
                Open
            </a>
        </div>
    </div>
</div>
