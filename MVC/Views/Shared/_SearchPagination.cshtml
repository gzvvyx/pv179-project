@model pv179.Models.SearchPaginationViewModel

@{
    if (Model == null)
    {
        return;
    }
    
    var section = Model.Section;
    var query = Model.Query;
    var pageParamName = section + "Page";
    var currentPage = Model.PageNumber;
    var totalPages = Model.TotalPages;
    var totalCount = Model.TotalCount;
    var pageSize = Model.PageSize;
    
    string BuildUrl(int pageNumber)
    {
        var queryParams = new List<string> { $"query={Uri.EscapeDataString(query)}" };
        
        foreach (var key in Context.Request.Query.Keys)
        {
            if (key != pageParamName && key != "query")
            {
                foreach (var value in Context.Request.Query[key])
                {
                    if (!string.IsNullOrEmpty(value))
                    {
                        queryParams.Add($"{key}={Uri.EscapeDataString(value!)}");
                    }
                }
            }
        }
        
        queryParams.Add($"{pageParamName}={pageNumber}");
        
        return "?" + string.Join("&", queryParams);
    }
}

@if (totalPages > 1)
{
    <div class="flex justify-center">
        <div class="join">
            @if (currentPage > 1)
            {
                <a href="@BuildUrl(currentPage - 1)" 
                   class="join-item btn btn-sm">
                    <icon name="chevron-left" />
                </a>
            }
            else
            {
                <button class="join-item btn btn-sm btn-disabled">
                    <icon name="chevron-left" />
                </button>
            }

            @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
            {
                if (i == currentPage)
                {
                    <button class="join-item btn btn-sm btn-active">@i</button>
                }
                else
                {
                    <a href="@BuildUrl(i)" 
                       class="join-item btn btn-sm">@i</a>
                }
            }

            @if (currentPage < totalPages)
            {
                <a href="@BuildUrl(currentPage + 1)" 
                   class="join-item btn btn-sm">
                    <icon name="chevron-right" />
                </a>
            }
            else
            {
                <button class="join-item btn btn-sm btn-disabled">
                    <icon name="chevron-right" />
                </button>
            }
        </div>
    </div>

    <div class="text-center mt-2 text-sm opacity-70">
        Showing @((currentPage - 1) * pageSize + 1) - @(Math.Min(currentPage * pageSize, totalCount)) of @totalCount
    </div>
}
