@model pv179.Models.HomeFeedViewModel
@{
    ViewData["Title"] = "Home";
}

<div class="container mx-auto px-4 py-8">
    @if (Model.HasSubscriptions)
    {
        <h1 class="text-3xl font-bold mb-6">Your Feed</h1>
        
        @if (Model.Videos.Any())
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                @foreach (var video in Model.Videos)
                {
                    <partial name="_VideoCard" model="video" />
                }
            </div>
        }
        else
        {
            <div class="text-center py-16">
                <icon name="video" class="w-16 h-16 mx-auto opacity-50 mb-4" />
                <p class="text-xl opacity-70">No videos from your subscriptions yet</p>
                <p class="opacity-50 mt-2">Check back later for new content!</p>
            </div>
        }
    }
    else
    {
        <div class="text-center py-16">
            <icon name="users" class="w-16 h-16 mx-auto opacity-50 mb-4" />
            <h2 class="text-2xl font-bold mb-4">Your feed is empty</h2>
            <p class="text-lg opacity-70 mb-6">Subscribe to creators to see their videos here</p>
            <a asp-controller="Search" asp-action="Index" class="btn btn-primary btn-lg">
                <icon name="search" class="w-5 h-5" />
                Discover Videos
            </a>
        </div>
    }
</div>
